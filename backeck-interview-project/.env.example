# =============================================================================
# Application
# =============================================================================
# Service identity used by logs, monitoring, and API documentation.
APP_NAME=ai-mock-interview-api
# HTTP port exposed by the NestJS application.
APP_PORT=3000
# Allowed values: development, test, staging, production.
APP_ENV=production
# Bind address. Use 0.0.0.0 in containers.
APP_HOST=0.0.0.0
# Global API route prefix without leading or trailing slashes.
APP_GLOBAL_PREFIX=api
# Comma-separated browser origins allowed by CORS.
APP_CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SWAGGER_PATH=/api/docs

MYSQL_ROOT_PASSWORD=test
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=ai_mock_interview
DATABASE_USER=ai_mock_interview_app
DATABASE_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=mysql://ai_mock_interview_app:CHANGE_ME_DATABASE_PASSWORD@mysql:3306/ai_mock_interview


REDIS_HOST=localhost
REDIS_PORT=password
REDIS_PASSWORD=
REDIS_DB=0

MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=

JWT_SECRET=CHANGE_ME_ACCESS_TOKEN_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_TOKEN_SECRET
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

AUTH_BCRYPT_SALT_ROUNDS=12
AUTH_OTP_TTL_SECONDS=300
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_PATH=/

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=CHANGE_ME_SMTP_USER
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM="AI Mock Interview <no-reply@example.com>"

GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
